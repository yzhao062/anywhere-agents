{
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(git tag -d *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh repo delete *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git branch --delete *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/_python\" \"$HOME/.claude/hooks/guard.py\"",
            "statusMessage": "Checking for compound cd and destructive commands..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/_python\" \"$HOME/.claude/hooks/session_bootstrap.py\"",
            "statusMessage": "Running anywhere-agents bootstrap if present..."
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  }
}
